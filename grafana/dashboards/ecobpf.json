{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "EcoBPF — Kernel-Level Carbon Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "⚡ System-Wide Energy Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          },
          "unit": "joule"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "title": "Total Energy (Joules)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(ecobpf_energy_joules)",
          "legendFormat": "Total Energy",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          },
          "unit": "watt"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Total Power (Watts)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(ecobpf_power_watts)",
          "legendFormat": "Total Power",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "#EAB839", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "massg"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Carbon Emission (gCO₂)",
      "type": "stat",
      "targets": [
        {
          "expr": "sum(ecobpf_carbon_grams_co2)",
          "legendFormat": "CO₂",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "purple", "value": 50 }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "title": "Tracked Processes",
      "type": "stat",
      "targets": [
        {
          "expr": "ecobpf_tracked_processes",
          "legendFormat": "Processes",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 101,
      "title": "📊 Energy Timeline",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "gradientMode": "scheme",
            "lineWidth": 2,
            "pointSize": 5,
            "stacking": { "mode": "normal" }
          },
          "unit": "joule"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max", "lastNotNull"] },
        "tooltip": { "mode": "multi" }
      },
      "title": "Energy Consumption by Component",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(ecobpf_cpu_energy_joules)",
          "legendFormat": "CPU",
          "refId": "A"
        },
        {
          "expr": "sum(ecobpf_memory_energy_joules)",
          "legendFormat": "Memory",
          "refId": "B"
        },
        {
          "expr": "sum(ecobpf_gpu_energy_joules)",
          "legendFormat": "GPU",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "🔬 Per-Process Breakdown",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "none" }
          },
          "unit": "joule"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table" }
      },
      "title": "Top 10 Energy Consumers",
      "type": "timeseries",
      "targets": [
        {
          "expr": "topk(10, ecobpf_energy_joules)",
          "legendFormat": "{{comm}} (PID {{pid}})",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30
          },
          "unit": "massg"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "title": "Carbon Footprint Timeline",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(ecobpf_carbon_grams_co2_total[1m])) * 60",
          "legendFormat": "gCO₂/min",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "🤖 AI Workload Attribution",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "joule"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 8,
      "options": {
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "title": "AI vs General Workload Energy",
      "type": "piechart",
      "targets": [
        {
          "expr": "sum(ecobpf_energy_joules * on(pid,comm) group_left ecobpf_ai_workload_detected == 1)",
          "legendFormat": "AI/ML Workloads",
          "refId": "A"
        },
        {
          "expr": "sum(ecobpf_energy_joules * on(pid,comm) group_left ecobpf_ai_workload_detected == 0)",
          "legendFormat": "General Processes",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-BlYlRd" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2
          },
          "unit": "watt"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 9,
      "title": "GPU Activity Power",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(ecobpf_gpu_energy_joules) by (comm)",
          "legendFormat": "{{comm}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 104,
      "title": "💾 Memory Pressure",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-YlRd" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 1
          },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 35 },
      "id": 10,
      "options": {
        "legend": { "displayMode": "table", "placement": "right" }
      },
      "title": "Memory Pressure — Page Faults & Reclaim Events",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(ecobpf_mem_page_faults_total{type=\"major\"}[1m])) * 60",
          "legendFormat": "Major Faults/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(ecobpf_mem_page_faults_total{type=\"minor\"}[1m])) * 60",
          "legendFormat": "Minor Faults/min",
          "refId": "B"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 105,
      "title": "🔍 Estimation Quality",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "#EAB839", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          },
          "max": 1,
          "min": 0,
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 44 },
      "id": 11,
      "options": {
        "reduceOptions": { "calcs": ["mean"] },
        "orientation": "horizontal"
      },
      "title": "ML Model Confidence",
      "type": "gauge",
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(ecobpf_estimation_confidence_bucket[5m]))",
          "legendFormat": "Median Confidence",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 60 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 44 },
      "id": 12,
      "title": "Container Energy Distribution",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(ecobpf_energy_joules) by (container_id)",
          "legendFormat": "{{container_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 60 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 50 },
      "id": 13,
      "title": "Container Energy by Name",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(ecobpf_energy_joules) by (container_name)",
          "legendFormat": "{{container_name}}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["ecobpf", "carbon", "energy", "greenops"],
  "templating": {
