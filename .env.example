# EcoBPF Environment Configuration
# Copy this file to .env and set values for your deployment.
# NEVER commit the .env file to version control.

# ─── Grafana ────────────────────────────────────────────────────────────────
# Grafana admin credentials — change before production deployment
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# ─── ML Estimator ───────────────────────────────────────────────────────────
# Carbon intensity for the deployment region (gCO2/kWh)
# Common values: US=420  EU=275  Global=475  France=50  India=720
CARBON_INTENSITY=475.0

# ─── Deployment (used by deploy workflow) ───────────────────────────────────
# Hostname or IP of the target host for health check verification
DEPLOY_HOST=your-server.example.com
# Port for the health check (default: 8080, matches websocket_addr in ecobpf.yaml)
DEPLOY_PORT=8080
# Health check path (default: /health)
HEALTH_PATH=/health
